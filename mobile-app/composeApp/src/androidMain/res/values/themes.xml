<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Noah" parent="android:Theme.Material.Light.NoActionBar" />
    <style name="Theme.Noah.SplashScreen" parent="Theme.SplashScreen">
        <!-- White background behind the icon -->
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <!-- The Mistral logo as the centred icon -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <!-- Theme to switch to once the splash is dismissed -->
        <item name="postSplashScreenTheme">@style/Theme.Noah</item>
    </style>

</resources>

